# --- App login gate -------------------------------------------------------
APP_PASSWORD=changeme

# --- SFMC Server-to-Server OAuth -----------------------------------------
# Reuse credentials from the Expert Series Webinar Invite Builder — same tenant.
MC_CLIENT_ID=
MC_CLIENT_SECRET=
MC_AUTH_BASE_URI=https://XXXXXXXX.auth.marketingcloudapis.com/
MC_REST_BASE_URI=https://XXXXXXXX.rest.marketingcloudapis.com/
MC_ACCOUNT_ID=

# --- SFMC Content Builder folder IDs -------------------------------------
# One folder per language for the email assets.
MC_EMAIL_FOLDER_ID_KO=863426
MC_EMAIL_FOLDER_ID_EN=
MC_EMAIL_FOLDER_ID_JP=
MC_EMAIL_FOLDER_ID_ZH_CN=
MC_EMAIL_FOLDER_ID_ZH_TW=

# Shared images folder (headshots, icons) — same across all languages.
MC_IMAGES_FOLDER_ID=792571

# Template folder (used only when re-bootstrapping by name search).
MC_TEMPLATE_FOLDER_ID=792570

# Single shared template asset ID — one template for all languages.
# Populate by running: python -m builder.bootstrap_template --asset-id 879310
MC_TEMPLATE_ID=879310

# --- Anthropic API (optional) --------------------------------------------
# When set, the AI extractor parses .eml requests into structured slot data.
# Without it, the parser falls back to heuristic HTML-structure extraction.
ANTHROPIC_API_KEY=
